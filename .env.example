# FastAPI 后端环境配置

# ============ 基础配置 ============
SECRET_KEY=your-secret-key-change-in-production
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8882

# ============ 数据库 ============
DATABASE_URL=postgresql://aigccloud:aigccloud123@postgres:5432/aigccloud
REDIS_URL=redis://redis:6379/0

# ============ Parse Server ============
PARSE_SERVER_URL=http://parse-server:1337/parse
PARSE_APP_ID=BTGAPPId
PARSE_MASTER_KEY=xxxxx # Master Key，用于服务端高权限操作
PARSE_REST_API_KEY=xxxxx
PARSE_JS_KEY=xxxxx # Electron 客户端动态获取

# ============ 微信支付 ============
# 基础配置 (API v2)
WECHAT_APP_ID=your-wechat-app-id
WECHAT_MCH_ID=your-wechat-mch-id
WECHAT_API_KEY=your-wechat-api-key-32chars
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/member/callback/wechat
WECHAT_TEST_MODE=true

# API v3 配置 (生产环境推荐，更安全)
WECHAT_API_V3_KEY=your-api-v3-key-32chars
WECHAT_SERIAL_NO=your-merchant-certificate-serial-no
WECHAT_PRIVATE_KEY_PATH=/app/certs/apiclient_key.pem

# ============ 邮件服务 ============
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM_NAME=巴特星球
SMTP_FROM_EMAIL=noreply@example.com

# ============ Web3 联盟链 ============
WEB3_RPC_URL=http://localhost:8545
WEB3_CHAIN_ID=1
INCENTIVE_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
INCENTIVE_WALLET_PRIVATE_KEY=your-private-key
COIN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ============ S3 对象存储 ============
S3_ENDPOINT=http://rustfs:9000
S3_ACCESS_KEY=rustfs
S3_SECRET_KEY=rustfs123456
S3_BUCKET=aigccloud

# ============ 日志 ============
LOG_LEVEL=INFO
