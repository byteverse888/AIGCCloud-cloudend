# ============================================================
# 激励结算模块配置
# 复制为 .env 后填入实际值
# ============================================================

# ========== K8s ==========
# 优先使用 kubeconfig 文件，留空则自动查找 ~/.kube/config
K8S_KUBECONFIG=
# 以下仅在不使用 kubeconfig 时需要配置
# K8S_API_SERVER=https://127.0.0.1:6443
# K8S_TOKEN=
# K8S_CA_CERT=
# K8S_PAGE_SIZE=500

# ========== Parse Server ==========
PARSE_SERVER_URL=http://localhost:1337/parse
PARSE_APP_ID=BTGAPPId
PARSE_MASTER_KEY=
PARSE_REST_API_KEY=

# ========== Web3 联盟链 ==========
# RPC URL 为空时自动进入 mock 模式（模拟转账，适用于开发测试）
WEB3_RPC_URL=
WEB3_CHAIN_ID=888
INCENTIVE_WALLET_PRIVATE_KEY=0x...

# ========== 在线激励曲线（非线性奖励） ==========
# 前 24h: 每小时 1× 基线分; 24-168h: 1.5×; 168-720h: 2×
# INCENTIVE_TIER1_HOURS=24
# INCENTIVE_TIER2_HOURS=168
# INCENTIVE_TIER3_HOURS=720
# INCENTIVE_TIER1_MULT=1.0
# INCENTIVE_TIER2_MULT=1.5
# INCENTIVE_TIER3_MULT=2.0

# ========== 连续在线时间系数 ==========
# 0-24h=1.0, 24-72h=1.2, 72-168h=1.5, 168h+=1.8
# INCENTIVE_CONT_COEFF_T1=1.0
# INCENTIVE_CONT_COEFF_T2=1.2
# INCENTIVE_CONT_COEFF_T3=1.5
# INCENTIVE_CONT_COEFF_T4=1.8

# ========== 掉线恢复机制 ==========
# <5min: 不清零; 5-30min: 衰减25%; >30min: 清零
# INCENTIVE_OFFLINE_GRACE_MIN=5
# INCENTIVE_OFFLINE_SOFT_MIN=30
# INCENTIVE_OFFLINE_DECAY=0.25

# ========== 网络成熟度系数 ==========
# <100节点=2.0, 100-1000=1.5, 1000-10000=1.0, >10000=0.8
# INCENTIVE_MATURITY_T1=100
# INCENTIVE_MATURITY_T2=1000
# INCENTIVE_MATURITY_T3=10000
# INCENTIVE_MATURITY_F1=2.0
# INCENTIVE_MATURITY_F2=1.5
# INCENTIVE_MATURITY_F3=1.0
# INCENTIVE_MATURITY_F4=0.8

# ========== 算力短缺系数 ==========
# 供需比驱动: <0.5=0.8, 0.5-0.8=1.0, 0.8-1.2=1.2, 1.2-1.5=1.5, >1.5=2.0
# INCENTIVE_SHORTAGE_F1=0.8
# INCENTIVE_SHORTAGE_F2=1.0
# INCENTIVE_SHORTAGE_F3=1.2
# INCENTIVE_SHORTAGE_F4=1.5
# INCENTIVE_SHORTAGE_F5=2.0

# ========== 可兑换积分 ==========
# 用户付费的 80% 转化为可兑换积分
# INCENTIVE_NODE_SHARE=0.8
# 积分-现金兑换率（1积分 = 0.01 元）
# INCENTIVE_EXCHANGE_RATE=0.01

# ========== 节点类型基线分 ==========
# 端侧=5, 轻量=10, 超级=20
# INCENTIVE_BASE_EDGE=5
# INCENTIVE_BASE_LIGHT=10
# INCENTIVE_BASE_SUPER=20

# ========== 结算 / 转账 ==========
# 最低转账积分额度
INCENTIVE_MIN_TRANSFER=1000
# 每批转账账户数
INCENTIVE_BATCH_SIZE=100
# 统计周期（小时）
# INCENTIVE_COLLECT_HOURS=1
# 清算时间（每天几点执行）
# INCENTIVE_SETTLEMENT_HOUR=2

# ========== 日志 ==========
# INCENTIVE_LOG_DIR=./incentive/logs
# INCENTIVE_LOG_FILE=incentive.log
INCENTIVE_LOG_LEVEL=INFO
# 单文件最大 50MB
# INCENTIVE_LOG_MAX_BYTES=52428800
# 保留轮转文件数
# INCENTIVE_LOG_BACKUP_COUNT=5
# 日志保留天数
# INCENTIVE_LOG_RETENTION_DAYS=30
